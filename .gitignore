# Dependencies
node_modules/

# Environment variables — NEVER commit these
.env
.env.*
!.env.example

# Uploads (user files — not part of the codebase)
uploads/*
!uploads/.gitkeep

# MacOS
.DS_Store

# Windows temp files
~$*

# Logs
*.log
npm-debug.log*

# Build artifacts
dist/
build/

# Word doc temp files (auto-generated by Office)
~$*.docx
~$*.xlsx
~$*.pptx
