# Copy this to .env and fill in your values (never commit .env)

# Server
NODE_ENV=production
PORT=3000

# Database (Railway provides this automatically when you add a Postgres service)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth
JWT_SECRET=your-very-long-random-secret-here
ALLOWED_ORIGIN=https://constructinv.varshyl.com

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (Resend — resend.com, free tier available)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Analytics (PostHog — posthog.com, free tier available)
POSTHOG_KEY=phc_xxxxxxxxxxxx

# AI Insights (Anthropic — console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# App URL (your Railway/custom domain)
APP_URL=https://constructinv.varshyl.com

# Admin access (comma-separated emails)
ADMIN_EMAILS=vaakapila@gmail.com
