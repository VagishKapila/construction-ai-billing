# Copy this to .env and fill in your values (never commit .env)

# Server
NODE_ENV=production
PORT=3000

# Database (Railway provides this automatically when you add a Postgres service)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth
JWT_SECRET=your-very-long-random-secret-here
ALLOWED_ORIGIN=https://constructinv.varshyl.com

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (Resend — resend.com, free tier available)
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=billing@varshyl.com

# Analytics (PostHog — posthog.com, free tier available)
POSTHOG_KEY=phc_xxxxxxxxxxxx

# AI Insights (Anthropic — console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# App URL (your Railway/custom domain)
APP_URL=https://constructinv.varshyl.com
BASE_URL=https://constructinv.varshyl.com

# Admin access (comma-separated emails)
ADMIN_EMAILS=vaakapila@gmail.com

# Stripe Payment Processing (Test mode keys start with pk_test_, sk_test_)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxx

# QuickBooks Online Integration (requires App set up in Intuit Developer Portal)
QB_CLIENT_ID=your-qb-client-id
QB_CLIENT_SECRET=your-qb-client-secret
QB_REDIRECT_URI=https://constructinv.varshyl.com/api/quickbooks/callback
QB_SANDBOX=true
QB_ENCRYPTION_KEY=your-32-char-hex-key-for-token-encryption

# Admin emergency reset (emergency password reset without email)
ADMIN_SECRET=your-secret-admin-key
