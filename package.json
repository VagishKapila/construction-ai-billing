{
  "name": "construction-ai-billing",
  "version": "1.0.0",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "build": "cd client && npm install && npm run build",
    "postinstall": "cd client && npm install",
    "test": "node qa_test.js",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:all": "node qa_test.js && npx playwright test",
    "payment-health": "node scripts/payment-health-check.js",
    "aria-daily": "node scripts/aria-daily.js",
    "test:real-user": "node tests/real-user/live-site-check.js",
    "test:real-user:staging": "ENV=staging node tests/real-user/live-site-check.js",
    "test:real-user:production": "ENV=production node tests/real-user/live-site-check.js"
  },
  "dependencies": {
    "@sentry/node": "^10.48.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.7.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.14.0",
    "pg": "^8.11.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "railway": "^2.0.17",
    "stripe": "^21.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "playwright": "^1.59.1"
  },
  "optionalDependencies": {
    "sharp": "^0.33.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
